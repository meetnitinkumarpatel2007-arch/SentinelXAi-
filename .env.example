# Copy this file to `.env` in the project root and fill in your own values.
# Never commit `.env` or share it in ZIP archives.

# PostgreSQL (Neon / Supabase)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/sentinelx_db?sslmode=require

# Neo4j AuraDB
NEO4J_URI=bolt+routing://YOUR-AURA-SUBDOMAIN.databases.neo4j.io:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Upstash Redis (serverless)
REDIS_URL=rediss://default:YOUR-UPSTASH-TOKEN@YOUR-UPSTASH-ENDPOINT:6379

# AI orchestration (LangGraph / LLM provider)
LLM_API_KEY=your-llm-api-key

# Backend runtime
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Frontend (Vite — only variables prefixed with VITE_ are exposed to the client)
VITE_API_BASE_URL=http://localhost:8000

# Rate Limiting Thresholds (Requirement 1: Configurable Limits)
# Auth endpoints (exponential backoff)
RATE_LIMIT_AUTH_BASE_DELAY=1
RATE_LIMIT_AUTH_MAX_DELAY=3600
RATE_LIMIT_AUTH_RESET=900

# Public endpoints
RATE_LIMIT_PUBLIC_HITS=60
RATE_LIMIT_PUBLIC_WINDOW=60

# Authenticated user endpoints
RATE_LIMIT_AUTHED_HITS=300
RATE_LIMIT_AUTHED_WINDOW=60